{
  "name": "auth-mini",
  "version": "0.3.0",
  "description": "Minimal, opinionated auth server for apps that just need auth.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zccz14/auth-mini.git"
  },
  "homepage": "https://github.com/zccz14/auth-mini#readme",
  "bugs": {
    "url": "https://github.com/zccz14/auth-mini/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./sdk/browser": {
      "types": "./dist/sdk/browser.d.ts",
      "import": "./dist/sdk/browser.js"
    },
    "./sdk/device": {
      "types": "./dist/sdk/device.d.ts",
      "import": "./dist/sdk/device.js"
    },
    "./sdk/api": {
      "types": "./dist/sdk/api.d.ts",
      "import": "./dist/sdk/api.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "node scripts/build-sdk.mjs",
    "generate:api": "openapi-ts",
    "check:generated:api": "node scripts/check-generated-api-sdk.mjs",
    "check:release-version": "node scripts/check-release-version.mjs",
    "test": "npm run typecheck && npm run test:unit && npm run test:integration",
    "test:unit": "node scripts/run-tests.js",
    "demo:build": "npm run build && npm --prefix examples/demo run build",
    "demo:build:web": "npm run build && npm --prefix examples/demo run build:web && node scripts/build-web-assets-archive.mjs",
    "demo:dev": "node scripts/dev-examples-demo.mjs",
    "demo:typecheck": "npm --prefix examples/demo run typecheck",
    "test:integration": "npm run build && vitest run tests/integration",
    "test:rust-e2e": "CARGO_HOME=$PWD/.cargo-home cargo build --manifest-path rust-backend/Cargo.toml && vitest run rust-e2e",
    "gco:main": "git fetch && git checkout origin/main",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {},
  "devDependencies": {
    "@hey-api/openapi-ts": "0.96.0",
    "@eslint/js": "^9.38.0",
    "better-sqlite3": "^12.4.1",
    "cbor-x": "^1.6.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.1",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.5",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.0",
    "yaml": "2.8.3"
  }
}
